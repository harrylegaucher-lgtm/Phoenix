    { "id": "tv11", "entityId": "te_reabsorption_passif", "traitId": "tr_molecules", "value": "Liposolubles non ionisées","starred": true,  "note": "La forme non ionisée est liposoluble et diffuse librement à travers les membranes tubulaires." },
    { "id": "tv12", "entityId": "te_reabsorption_passif", "traitId": "tr_pkA",       "value": "PKA",                     "starred": true,  "note": "La réabsorption passive dépend du pKa de la molécule et du pH urinaire (équilibre Henderson-Hasselbalch)." },

    { "id": "tv13", "entityId": "te_acides_faibles",  "traitId": "tr_molecules", "value": "Acides faibles",              "starred": false, "note": "" },
    { "id": "tv14", "entityId": "te_acides_faibles",  "traitId": "tr_pkA",       "value": "PKA < 2,5 → réabsorption nulle",    "starred": true, "note": "Si pKa < 2,5 : molécule toujours ionisée → non réabsorbée (éliminée dans les urines)." },
    { "id": "tv15", "entityId": "te_acides_faibles",  "traitId": "tr_pkA",       "value": "PKA 2,5–7,5 → pH dépendante", "starred": true,  "note": "Zone intermédiaire : la réabsorption dépend du pH urinaire. Alcalinisation → ionisation → élimination accrue." },
    { "id": "tv16", "entityId": "te_acides_faibles",  "traitId": "tr_pkA",       "value": "PKA > 7,5 → réabsorption intense", "starred": true, "note": "Si pKa > 7,5 : molécule peu ionisée à pH urinaire → très réabsorbée → longue demi-vie." },

    { "id": "tv17", "entityId": "te_bases_faibles",   "traitId": "tr_molecules", "value": "Bases faibles",               "starred": false, "note": "" },
    { "id": "tv18", "entityId": "te_bases_faibles",   "traitId": "tr_pkA",       "value": "PKA < 6 → réabsorption intense",   "starred": true, "note": "Base faible de faible pKa : peu ionisée → réabsorbée (inverse des acides faibles)." },
    { "id": "tv19", "entityId": "te_bases_faibles",   "traitId": "tr_pkA",       "value": "PKA 6–12 → pH dépendante",    "starred": true,  "note": "Zone intermédiaire pour les bases : acidification des urines → ionisation → élimination. Utile en cas de surdosage (ex: amphétamines)." },
    { "id": "tv20", "entityId": "te_bases_faibles",   "traitId": "tr_pkA",       "value": "PKA > 12 → réabsorption nulle",    "starred": true, "note": "Si pKa > 12 : toujours ionisée → non réabsorbée." }
  ]
