    { "id": "tv7",  "entityId": "te_reabsorption_actif",  "traitId": "tr_type",      "value": "Actif (transporteurs)",   "starred": false, "note": "" },
    { "id": "tv8",  "entityId": "te_reabsorption_actif",  "traitId": "tr_molecules", "value": "Endogènes semblables AA", "starred": true,  "note": "Molécules endogènes structurellement proches des acides aminés (AA) — transportées par les mêmes carriers." },
    { "id": "tv9",  "entityId": "te_reabsorption_actif",  "traitId": "tr_exemple",   "value": "α-Méthyl Dopa",           "starred": false, "note": "" },

